# R@K FP&A OS — environment variables
# Copy to .env.local and fill in. Without a key the copilot runs in
# grounded "demo mode" (no real model calls).

# --- Provider API keys ---
# Locally you can add keys in Admin → Providers (stored in .rak/). In production
# (Vercel — read-only filesystem) that store can't be written, so set provider
# keys here instead. Any set here are merged in automatically (one var per
# provider); leave blank to manage via the Admin UI locally.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
DEEPINFRA_API_KEY=

# --- Auth (login required for /dashboard, /workspace, /fpa, /admin + APIs) ---
# Signed-cookie sessions. REQUIRED in production: without a real AUTH_SECRET the
# app fails closed (logins are rejected) so sessions can't be forged.
# Generate: `openssl rand -base64 32`.
AUTH_SECRET=

# Fixed accounts: 1 admin + 2 guests. ONLY the admin sees/edits provider API
# keys (/admin). Defaults below are for local dev — CHANGE before sharing.
ADMIN_USER=admin
ADMIN_PASS=nexera-admin
GUEST1_USER=guest1
GUEST1_PASS=guest-one
GUEST2_USER=guest2
GUEST2_PASS=guest-two

# --- Image generation (/api/generate/image) ---
# Order of preference: Together → Hugging Face → Pollinations (keyless, default).
# Leave all blank and image gen still works via free keyless Pollinations.
TOGETHER_API_KEY=
HF_TOKEN=

# --- Video generation (/api/generate/video) ---
# Replicate free-tier credits. Required for text-to-video (no keyless option).
REPLICATE_API_TOKEN=
# Optional override of the text-to-video model (owner/name).
REPLICATE_VIDEO_MODEL=wan-video/wan-2.1-t2v-480p
